from motor import motor1, destroy

def drive(direction):
    low_speed = 25
    if direction == 0:
        motor1.throttle = 0
        return
    throttle = low_speed / 100.0
    if direction == -1:
        throttle = -throttle
    motor1.throttle = throttle

if __name__ == '__main__':
    print("Avant 25%")
    drive(1)
    time.sleep(2)

    print("Stop")
    drive(0)
    time.sleep(1)

    print("Arrière 25%")
    drive(-1)
    time.sleep(2)

    print("Stop final")
    drive(0)
    destroy()
